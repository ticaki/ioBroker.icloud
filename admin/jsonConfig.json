{
    "i18n": true,
    "type": "tabs",
    "items": {
        "_tabGeneral": {
            "type": "panel",
            "label": "generalTab",
            "items": {
                "username": {
                    "type": "text",
                    "label": "username",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6
                },
                "password": {
                    "type": "password",
                    "label": "password",
                    "newLine": false,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6
                },
                "_smsMfaPanel": {
                    "type": "custom",
                    "name": "ConfigCustomIcloudSet/Components/SmsMfaPanel",
                    "url": "custom/customComponents.js",
                    "i18n": true,
                    "bundlerType": "module",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12
                },
                "_donationHint": {
                    "type": "staticLink",
                    "label": "donationText",
                    "href": "https://paypal.me/ticaki",
                    "button": true,
                    "color": "primary",
                    "variant": "outlined",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3
                }
            }
        },
        "_tabFindMy": {
            "type": "panel",
            "label": "findMyTab",
            "items": {
                "findMyEnabled": {
                    "type": "checkbox",
                    "label": "findMyEnabled",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": true
                },
                "findMyInterval": {
                    "type": "number",
                    "label": "findMyInterval",
                    "help": "findMyIntervalHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 1,
                    "max": 120,
                    "step": 1,
                    "default": 5,
                    "disabled": "!data.findMyEnabled || !!data.findMyIntervalExpertEnabled"
                },
                "findMyIntervalExpertEnabled": {
                    "type": "checkbox",
                    "label": "findMyIntervalExpertEnabled",
                    "help": "findMyIntervalExpertEnabledHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false,
                    "disabled": "!data.findMyEnabled"
                },
                "findMyIntervalExpert": {
                    "type": "number",
                    "label": "findMyIntervalExpert",
                    "help": "findMyIntervalExpertHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 30,
                    "max": 120,
                    "step": 1,
                    "default": 60,
                    "hidden": "!data.findMyIntervalExpertEnabled",
                    "disabled": "!data.findMyEnabled || !data.findMyIntervalExpertEnabled"
                },
                "locationPoints": {
                    "type": "table",
                    "label": "locationPoints",
                    "help": "locationPointsHelp",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "items": [
                        {
                            "type": "number",
                            "label": "locationPointIndex",
                            "attr": "index",
                            "min": 0,
                            "max": 100000000000000,
                            "step": 1,
                            "validator": "const x={};for (const c of globalData.locationPoints) {if (x[c.index]==='x') return false; x[c.index]='x';}; return !isNaN(data.index);",
                            "validatorNoSaveOnError": true
                        },
                        {
                            "type": "coordinates",
                            "label": "locationPointCoordinates",
                            "longitudeName": "longitude",
                            "latitudeName": "latitude",
                            "attr": "coordinates"
                        },
                        {
                            "type": "text",
                            "label": "locationPointName",
                            "attr": "name"
                        }
                    ],
                    "disabled": "!data.findMyEnabled"
                },
                "_findMyDevicesHeader": {
                    "type": "header",
                    "text": "findMyDevicesHeader",
                    "size": 5,
                    "newLine": true
                },
                "_findMyDevices": {
                    "type": "custom",
                    "name": "ConfigCustomIcloudSet/Components/FindMyDevices",
                    "url": "custom/customComponents.js",
                    "i18n": true,
                    "bundlerType": "module",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12
                }
            }
        },
        "_tabSettings": {
            "type": "panel",
            "label": "settingsTab",
            "items": {
                "_calendarHeader": {
                    "type": "header",
                    "text": "calendarHeader",
                    "size": 5,
                    "newLine": true
                },
                "calendarEnabled": {
                    "type": "checkbox",
                    "label": "calendarEnabled",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false
                },
                "calendarEventCount": {
                    "type": "number",
                    "label": "calendarEventCount",
                    "help": "calendarEventCountHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 1,
                    "max": 50,
                    "step": 1,
                    "default": 10,
                    "disabled": "!data.calendarEnabled"
                },
                "calendarMonths": {
                    "type": "number",
                    "label": "calendarMonths",
                    "help": "calendarMonthsHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 1,
                    "max": 12,
                    "step": 1,
                    "default": 2,
                    "disabled": "!data.calendarEnabled"
                },
                "calendarInterval": {
                    "type": "number",
                    "label": "calendarInterval",
                    "help": "calendarIntervalHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 5,
                    "max": 1440,
                    "step": 1,
                    "default": 60,
                    "disabled": "!data.calendarEnabled"
                },
                "_remindersHeader": {
                    "type": "header",
                    "text": "remindersHeader",
                    "size": 5,
                    "newLine": true
                },
                "remindersEnabled": {
                    "type": "checkbox",
                    "label": "remindersEnabled",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false
                },
                "remindersItemCount": {
                    "type": "number",
                    "label": "remindersItemCount",
                    "help": "remindersItemCountHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 1,
                    "max": 50,
                    "step": 1,
                    "default": 10,
                    "disabled": "!data.remindersEnabled"
                },
                "remindersInterval": {
                    "type": "number",
                    "label": "remindersInterval",
                    "help": "remindersIntervalHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 5,
                    "max": 1440,
                    "step": 1,
                    "default": 60,
                    "disabled": "!data.remindersEnabled"
                },
                "remindersFilter": {
                    "type": "select",
                    "label": "remindersFilter",
                    "help": "remindersFilterHelp",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "options": [
                        { "value": "due", "label": "remindersFilterDue" },
                        { "value": "all", "label": "remindersFilterAll" }
                    ],
                    "default": "due",
                    "disabled": "!data.remindersEnabled"
                },
                "remindersShowCompleted": {
                    "type": "checkbox",
                    "label": "remindersShowCompleted",
                    "help": "remindersShowCompletedHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false,
                    "disabled": "!data.remindersEnabled"
                },
                "_remindersResync": {
                    "type": "sendTo",
                    "command": "resetRemindersSyncMap",
                    "label": "remindersResync",
                    "help": "remindersResyncHelp",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "icon": "refresh",
                    "variant": "outlined",
                    "disabled": "!data.remindersEnabled",
                    "confirm": {
                        "title": "remindersResync",
                        "text": "remindersResyncHelp",
                        "ok": "OK",
                        "cancel": "Cancel"
                    }
                },
                "_contactsHeader": {
                    "type": "header",
                    "text": "contactsHeader",
                    "size": 5,
                    "newLine": true
                },
                "contactsEnabled": {
                    "type": "checkbox",
                    "label": "contactsEnabled",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false
                },
                "contactsInterval": {
                    "type": "number",
                    "label": "contactsInterval",
                    "help": "contactsIntervalHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 30,
                    "max": 1440,
                    "step": 1,
                    "default": 60,
                    "disabled": "!data.contactsEnabled"
                },
                "contactsWriteStates": {
                    "type": "checkbox",
                    "label": "contactsWriteStates",
                    "help": "contactsWriteStatesHelp",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false,
                    "disabled": "!data.contactsEnabled"
                },
                "contactsBirthdayStates": {
                    "type": "checkbox",
                    "label": "contactsBirthdayStates",
                    "help": "contactsBirthdayStatesHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false,
                    "disabled": "!data.contactsEnabled"
                },
                "contactsGroups": {
                    "type": "chips",
                    "label": "contactsGroups",
                    "help": "contactsGroupsHelp",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 8,
                    "lg": 6,
                    "xl": 6,
                    "disabled": "!data.contactsEnabled || !data.contactsWriteStates"
                },
                "_notesHeader": {
                    "type": "header",
                    "text": "notesHeader",
                    "size": 5,
                    "newLine": true
                },
                "notesEnabled": {
                    "type": "checkbox",
                    "label": "notesEnabled",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false
                },
                "notesInterval": {
                    "type": "number",
                    "label": "notesInterval",
                    "help": "notesIntervalHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 15,
                    "max": 1440,
                    "step": 1,
                    "default": 60,
                    "disabled": "!data.notesEnabled"
                },
                "_driveHeader": {
                    "type": "header",
                    "text": "driveHeader",
                    "size": 5,
                    "newLine": true
                },
                "driveEnabled": {
                    "type": "checkbox",
                    "label": "driveEnabled",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false
                },
                "_photosHeader": {
                    "type": "header",
                    "text": "photosHeader",
                    "size": 5,
                    "newLine": true
                },
                "photosEnabled": {
                    "type": "checkbox",
                    "label": "photosEnabled",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false
                },
                "photosInterval": {
                    "type": "number",
                    "label": "photosInterval",
                    "help": "photosIntervalHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 15,
                    "max": 1440,
                    "step": 1,
                    "default": 60,
                    "disabled": "!data.photosEnabled"
                },
                "_accountHeader": {
                    "type": "header",
                    "text": "accountHeader",
                    "size": 5,
                    "newLine": true
                },
                "accountStorageEnabled": {
                    "type": "checkbox",
                    "label": "accountStorageEnabled",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false
                },
                "accountStorageInterval": {
                    "type": "number",
                    "label": "accountStorageInterval",
                    "help": "accountStorageIntervalHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 30,
                    "max": 1440,
                    "step": 1,
                    "default": 60,
                    "disabled": "!data.accountStorageEnabled"
                }
            }
        },
        "_tabGeocoding": {
            "type": "panel",
            "label": "geocodingTab",
            "items": {
                "geocodingProvider": {
                    "type": "select",
                    "label": "geocodingProvider",
                    "help": "geocodingProviderHelp",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "options": [
                        { "value": "none", "label": "geocodingProviderNone" },
                        { "value": "local", "label": "geocodingProviderLocal" },
                        { "value": "traccar", "label": "geocodingProviderTraccar" },
                        { "value": "nominatim", "label": "geocodingProviderNominatim" },
                        { "value": "opencage", "label": "geocodingProviderOpencage" }
                    ],
                    "default": "none"
                },
                "_localHeader": {
                    "type": "header",
                    "text": "geocodingLocalHeader",
                    "size": 5,
                    "newLine": true,
                    "hidden": "data.geocodingProvider !== 'local'"
                },
                "_localInfo": {
                    "type": "staticText",
                    "text": "geocodingLocalInfo",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "hidden": "data.geocodingProvider !== 'local'"
                },
                "_externalHeader": {
                    "type": "header",
                    "text": "geocodingExternalHeader",
                    "size": 5,
                    "newLine": true,
                    "hidden": "data.geocodingProvider === 'none' || data.geocodingProvider === 'local'"
                },
                "geocodingUrl": {
                    "type": "text",
                    "label": "geocodingUrl",
                    "help": "geocodingUrlHelp",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "hidden": "data.geocodingProvider === 'none' || data.geocodingProvider === 'local'"
                },
                "geocodingApiKey": {
                    "type": "text",
                    "label": "geocodingApiKey",
                    "help": "geocodingApiKeyHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "hidden": "data.geocodingProvider === 'none' || data.geocodingProvider === 'local'"
                },
                "_infoTraccar": {
                    "type": "staticText",
                    "text": "geocodingInfoTraccar",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "hidden": "data.geocodingProvider !== 'traccar'"
                },
                "_infoNominatim": {
                    "type": "staticText",
                    "text": "geocodingInfoNominatim",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "hidden": "data.geocodingProvider !== 'nominatim'"
                },
                "_infoOpencage": {
                    "type": "staticText",
                    "text": "geocodingInfoOpencage",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "hidden": "data.geocodingProvider !== 'opencage'"
                },
                "_cacheHeader": {
                    "type": "header",
                    "text": "geocodingCacheHeader",
                    "size": 5,
                    "newLine": true,
                    "hidden": "data.geocodingProvider === 'none'"
                },
                "geocodingCacheSize": {
                    "type": "select",
                    "label": "geocodingCacheSize",
                    "help": "geocodingCacheSizeHelp",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "options": [
                        { "value": "small", "label": "geocodingCacheSmall" },
                        { "value": "medium", "label": "geocodingCacheMedium" },
                        { "value": "large", "label": "geocodingCacheLarge" }
                    ],
                    "default": "small",
                    "hidden": "data.geocodingProvider === 'none'"
                }
            }
        },
        "_tabDriveSync": {
            "type": "panel",
            "label": "driveSyncTab",
            "hidden": "!data.driveEnabled",
            "items": {
                "_driveSyncHeader": {
                    "type": "header",
                    "text": "driveSyncHeader",
                    "size": 5,
                    "newLine": true
                },
                "_driveSyncInfo": {
                    "type": "staticText",
                    "text": "driveSyncInfo",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12
                },
                "driveSyncEnabled": {
                    "type": "checkbox",
                    "label": "driveSyncEnabled",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "default": false
                },
                "driveSyncInterval": {
                    "type": "number",
                    "label": "driveSyncInterval",
                    "help": "driveSyncIntervalHelp",
                    "newLine": false,
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3,
                    "min": 5,
                    "max": 1440,
                    "step": 1,
                    "default": 60,
                    "disabled": "!data.driveSyncEnabled"
                },
                "_driveSyncComponent": {
                    "type": "custom",
                    "name": "ConfigCustomIcloudSet/Components/DriveSync",
                    "url": "custom/customComponents.js",
                    "i18n": true,
                    "bundlerType": "module",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "hidden": "!data.driveSyncEnabled"
                }
            }
        }
    }
}
